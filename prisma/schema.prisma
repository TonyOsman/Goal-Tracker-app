generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  telegramChatId  String?   @unique
  telegramLinkCode String? @unique
  timezone        String    @default("America/Sao_Paulo")
  dailyNudge      String?
  createdAt       DateTime  @default(now())
  goals          Goal[]
  reviews        Review[]
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  title        String
  whyItMatters String?
  scope        Scope
  type         GoalType
  tags         String[]
  parentId     String?
  parent       Goal?      @relation("GoalHierarchy", fields: [parentId], references: [id])
  children     Goal[]     @relation("GoalHierarchy")
  targetValue  Float?
  initialValue Float?
  currentValue Float?
  unit         String?
  status       Status     @default(NOT_STARTED)
  startDate    DateTime
  dueDate      DateTime
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  habitLogs    HabitLog[]
  reminders    Reminder[]
}

model HabitLog {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id])
  date      DateTime @db.Date
  completed Boolean  @default(false)
  value     Float?
  note      String?

  @@unique([goalId, date])
}

model Review {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  period      ReviewPeriod
  reviewDate  DateTime
  wentWell    String?
  didntGo     String?
  adjustments String?
  aiDraft     String?
  createdAt   DateTime     @default(now())
}

model Reminder {
  id           String  @id @default(cuid())
  goalId       String
  goal         Goal    @relation(fields: [goalId], references: [id])
  scheduleCron String
  channel      Channel @default(TELEGRAM)
  message      String?
  active       Boolean @default(true)
}

enum Scope {
  YEAR
  QUARTER
  MONTH
  WEEK
  DAY
}

enum GoalType {
  OUTCOME
  METRIC
  HABIT
}

enum Status {
  NOT_STARTED
  IN_PROGRESS
  DONE
  MISSED
  DEFERRED
}

enum ReviewPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum Channel {
  TELEGRAM
  EMAIL
  IN_APP
}
